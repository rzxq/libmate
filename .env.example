# Токен бота, который дал тебе @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Ключ Anthropic API (console.anthropic.com -> Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Необязательно: ID канала/чата, куда постятся отзывы (фича "поделиться")
# Формат: -1001234567890
COMMUNITY_CHAT_ID=

# Путь к файлу базы данных (для Railway можно оставить как есть)
DATABASE_PATH=bookbot.db
