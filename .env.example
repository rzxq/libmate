# Токен бота, который дал тебе @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Ключ Anthropic API (console.anthropic.com -> Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Ключ Google Books API (бесплатный) — без него поиск может мгновенно
# проваливаться из-за общих лимитов на IP облачных хостингов.
# Как получить: см. README, раздел "Google Books API".
GOOGLE_BOOKS_API_KEY=

# Токен провайдера оплаты ЮKassa: @BotFather -> Payments -> ЮKassa
YOOKASSA_PROVIDER_TOKEN=

# Сколько книг доступно бесплатно до подписки
FREE_BOOK_LIMIT=15

# Путь к файлу базы данных. На Railway с подключённым Volume используй
# путь внутри тома, например /data/bookbot.db — иначе база будет стираться
# при каждом передеплое.
DATABASE_PATH=bookbot.db
